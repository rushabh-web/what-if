# Copy to `.env` and fill in real values. `.env` is gitignored; this file is NOT,
# so never put real secrets here.

# --- Database ---
# Local dev defaults to SQLite. For Postgres (Railway/Neon), set a full URL, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./fifa.db

# --- Data provider ---
# "seed" (offline, default) or "football-data"
DATA_PROVIDER=seed
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- AI explanation layer ---
# Provider is auto-selected: Gemini (if GEMINI_API_KEY) > Anthropic (if
# ANTHROPIC_API_KEY) > deterministic template (no key required).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Monte Carlo ---
MONTE_CARLO_RUNS=20000

# --- CORS: comma-separated origins allowed to call the API ---
CORS_ORIGINS=http://localhost:3000
